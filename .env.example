# Local PostgreSQL (for development)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tst_crm

# Neon PostgreSQL (for production)
# DATABASE_URL=postgresql://your-user:your-password@your-host.neon.tech/your-database?sslmode=require

# API Authentication
API_KEY=your-api-key-here

# SMS Provider (aligo | nhn)
SMS_PROVIDER=aligo

# Aligo SMS API
ALIGO_API_KEY=your-aligo-api-key
ALIGO_USER_ID=your-aligo-user-id
ALIGO_SENDER=0200000000
ALIGO_TESTMODE=Y

# NHN Cloud SMS API
NHN_SMS_APP_KEY=your-app-key
NHN_SMS_SECRET_KEY=your-secret-key
NHN_SMS_SENDER=0200000000

# Auth (NextAuth)
AUTH_ENABLED=true
NEXT_PUBLIC_AUTH_ENABLED=true
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-secret-here

# Admin Seed
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme123

# Sentry
SENTRY_DSN=your-sentry-dsn-here
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn-here
SENTRY_TRACES_SAMPLE_RATE=1.0
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=1.0

# CORS (comma-separated, omit for wildcard in dev)
# ALLOWED_ORIGINS=https://your-domain.com
